# ─────────────────────────────────────────────
#  Yene Lottery Bot — Environment Variables
# ─────────────────────────────────────────────

# BOT TOKEN from @BotFather
BOT_TOKEN=your_bot_token_here

# ADMIN GROUP/CHANNEL where payment screenshots are forwarded
ADMIN_GROUP_ID=-100xxxxxxxxxx

# PUBLIC GROUP/CHANNEL where winners are announced
PUBLIC_GROUP_ID=-100xxxxxxxxxx

# SUPER ADMIN Telegram User IDs (comma-separated)
SUPER_ADMIN_IDS=123456789,987654321

# ── PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yene_lottery
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Database URL (alternative to individual settings)
DATABASE_URL=postgresql://postgres:your_db_password_here@localhost:5432/yene_lottery

# ── Optional ────────────────────────────────────
# Set to True in production
DEBUG=False
